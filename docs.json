{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Convo Docs",
  "description": "Documentation for Convo — the AI-moderated focus group platform.",
  "colors": {
    "primary": "#c44b25",
    "light": "#e87b5d",
    "dark": "#a33d1e"
  },
  "background": {
    "light": "#faf8f5",
    "dark": "#1a1a1a"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Using Convo",
            "pages": [
              "using-convo/setting-up-a-study",
              "using-convo/recruiting-participants",
              "using-convo/live-sessions",
              "using-convo/analysis"
            ]
          },
          {
            "group": "Results",
            "pages": [
              "results/summary",
              "results/deep-dive-and-responses",
              "results/themes",
              "results/video-clips",
              "results/explore"
            ]
          }
        ]
      },
      {
        "tab": "Resources",
        "groups": [
          {
            "group": "Support",
            "pages": ["resources/faq", "resources/security-and-privacy"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://www.convo.build",
          "icon": "arrow-up-right-from-square"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@useconvo.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://www.convo.build"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/useconvo"
    }
  }
}
